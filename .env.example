# ============================================================
#  F . R . I . D . A . Y  —  Environment Configuration
#  Copy this file to .env and fill in your values
# ============================================================

# ----------------------------------------------------------
# REQUIRED — LLM Brain
# Get your free key at: https://console.groq.com/
# ----------------------------------------------------------
GROQ_API_KEY=your_groq_key_here

# ----------------------------------------------------------
# VOICE SYNTHESIS — Edge TTS (primary) + Kokoro ONNX (offline fallback)
# No API key needed. Edge TTS is free via Microsoft.
# Kokoro runs fully offline on CPU.
# To change voices, edit EDGE_TTS_VOICE / Kokoro voice in server.py
# ----------------------------------------------------------

# ----------------------------------------------------------
# IDENTITY — How F.R.I.D.A.Y. addresses you
# USER_NAME : your name (e.g. Tony, Sanu, Alex)
# HONORIFIC : sir / ma'am / boss / chief etc.
#             Used sparingly — greetings & important moments only
# ----------------------------------------------------------
USER_NAME=Sanu
HONORIFIC=sir

# ----------------------------------------------------------
# WEATHER — Real-time weather via OpenWeatherMap (free)
# Get your free key at: https://openweathermap.org/api
# Leave WEATHER_* blank = auto-detect location from your IP
# ----------------------------------------------------------
OPENWEATHERMAP_API_KEY=your_openweathermap_key_here

# ----------------------------------------------------------
# CALENDAR — Google/Windows Calendar integration
# "auto" = let F.R.I.D.A.Y. detect all calendars automatically
# Or set specific account emails (comma-separated):
# CALENDAR_ACCOUNTS=you@gmail.com,work@company.com
# ----------------------------------------------------------
CALENDAR_ACCOUNTS=auto

# ----------------------------------------------------------
# GOOGLE INTEGRATION — Enable/Disable Gmail and Google Calendar features
# ----------------------------------------------------------
# GMAIL_INTEGRATION=false

# ----------------------------------------------------------
# CLAUDE CODE — Skip interactive permission prompts
# Keep "true" for voice use (prompts would hang silently)
# Set "false" only if running F.R.I.D.A.Y. in a visible terminal
# ----------------------------------------------------------
# FRIDAY_SKIP_PERMISSIONS=true

# ----------------------------------------------------------
# FACE UNLOCK — Webcam-based identity check at startup
# Requires:  pip install opencv-contrib-python
# Step 1 — Train your face (run once):
#   python face_auth.py --train
# Step 2 — Enable here:
#   FACE_AUTH=true
# If face doesn't match → F.R.I.D.A.Y. enters restricted mode
# (email, notes, files commands are blocked)
# Emergency bypass:  python server.py --skip-face-auth
# ----------------------------------------------------------
# FACE_AUTH=false

# ----------------------------------------------------------
# VOICE PASSPHRASE — spoken fallback when face auth fails
# Pick any phrase you will remember (e.g. a movie quote)
# Uses Google free STT (needs internet at startup)
# Leave blank to disable voice fallback
# ----------------------------------------------------------
# VOICE_PASSPHRASE=your secret phrase here

# ----------------------------------------------------------
# TAVILY — Real-time web search for current events/facts
# Free key (1000 searches/month): https://app.tavily.com
# Without this, F.R.I.D.A.Y. answers from training data only
# (e.g. "who is the current CM" may give stale answers).
# ----------------------------------------------------------
TAVILY_API_KEY=your_tavily_key_here
