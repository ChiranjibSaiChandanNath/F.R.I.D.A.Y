# ============================================================
#  J . A . R . V . I . S  —  Git Exclusion List
# ============================================================

# ------------------------------------------------------------
# Environment Configurations (Strictly Private)
# ------------------------------------------------------------
.env
.env.local

# ------------------------------------------------------------
# Python / Cache / Testing Files
# ------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.coverage

# ------------------------------------------------------------
# Project Dependencies
# ------------------------------------------------------------
node_modules/
.venv/
venv/
frontend/node_modules/
desktop-overlay/node_modules/

# ------------------------------------------------------------
# Local Runtime Databases & App Data (Keep private)
# ------------------------------------------------------------
*.db
*.db-shm
*.db-wal
data/*.jsonl
data/active_session.json
data/.jarvis_output.txt
data/credentials.json
data/token.json
data/face_auth/

# ------------------------------------------------------------
# Certificates / SSL Keys
# ------------------------------------------------------------
*.pem

# ------------------------------------------------------------
# Production Builds
# ------------------------------------------------------------
dist/
.vite/
frontend/.vite/

# ------------------------------------------------------------
# IDE Configurations & System Files
# ------------------------------------------------------------
.DS_Store
.vscode/
.idea/
.claude/
.arch/
context/

# ------------------------------------------------------------
# Large Binary Assets & ONNX Models (Keep out of Git)
# ------------------------------------------------------------
*.onnx
*.bin
